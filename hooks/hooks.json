{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit",
        "hooks": [{ "type": "command", "command": "npx -y -p @pushary/agent-hooks@latest pushary-hook", "timeout": 120 }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Write|Edit",
        "hooks": [{ "type": "command", "command": "npx -y -p @pushary/agent-hooks@latest pushary-post-hook", "timeout": 10 }]
      }
    ],
    "Stop": [
      { "hooks": [{ "type": "command", "command": "npx -y -p @pushary/agent-hooks@latest pushary-stop-hook", "timeout": 10 }] }
    ],
    "UserPromptSubmit": [
      { "hooks": [{ "type": "command", "command": "npx -y -p @pushary/agent-hooks@latest pushary-prompt-hook", "timeout": 10 }] }
    ]
  }
}
